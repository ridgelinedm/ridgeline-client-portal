# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google OAuth (one set of creds for the agency's Google account) ────────
# Create at https://console.cloud.google.com/apis/credentials
# Enable APIs: Search Console API, Google Analytics Data API,
#              Business Profile Performance API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Obtain by running through OAuth once with offline access; store the refresh
# token here. Treat like a password.
GOOGLE_REFRESH_TOKEN=

# ─── Ahrefs ─────────────────────────────────────────────────────────────────
# Get from https://ahrefs.com/api (free on paid plans)
AHREFS_API_KEY=

# ─── Cron ───────────────────────────────────────────────────────────────────
# Random string. Vercel Cron sends this as `Authorization: Bearer ...`.
CRON_SECRET=
